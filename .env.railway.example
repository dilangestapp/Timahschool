APP_NAME="TIMAH SCHOOL"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-railway-domain.up.railway.app
ASSET_URL=

TIMAHSCHOOL_ADMIN_PATH=backoffice-access
TIMAHSCHOOL_ADMIN_ACCESS_CODE=

LOG_CHANNEL=stack
LOG_LEVEL=info

DB_CONNECTION=mysql
# Railway MySQL is auto-supported by config/database.php via MYSQL_URL / MYSQLHOST vars.
# You can leave the DB_* vars empty if Railway injects MYSQL* vars from the MySQL service.
DB_HOST=
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

FILESYSTEM_DISK=public
PUBLIC_FILESYSTEM_ROOT=/data/public

CACHE_DRIVER=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_LIFETIME=120
SESSION_DOMAIN=
SESSION_SECURE_COOKIE=true

NOTCHPAY_PUBLIC_KEY=
NOTCHPAY_PRIVATE_KEY=
NOTCHPAY_BASE_URL=https://api.notchpay.co
NOTCHPAY_CALLBACK_URL="${APP_URL}/payment/callback"
NOTCHPAY_TEST_MODE=false

# Optional if you later enable mail
MAIL_MAILER=log
MAIL_HOST=
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"
